 now # ============================================
# NexusNights Intelligence Engine
# Environment Configuration
# ============================================

# REQUIRED: Google Gemini API Key
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# OPTIONAL: Ollama Sidekick Configuration
# ============================================

# Ollama endpoint (default: http://localhost:11434)
# If running Ollama on a different machine or port, update this
OLLAMA_ENDPOINT=http://localhost:11434

# Ollama model to use for the Sidekick
# Recommended: llama3.1:8b (good balance of speed and quality)
# Alternatives: llama3.1:70b (higher quality), mistral:7b (faster)
OLLAMA_MODEL=llama3.1:8b

# ============================================
# IMPORTANT: Ollama CORS Configuration
# ============================================
# To allow the browser to communicate with Ollama, you must
# start Ollama with CORS enabled:
#
#   export OLLAMA_ORIGINS="*"
#   ollama serve
#
# Or for more restrictive CORS (recommended for production):
#   export OLLAMA_ORIGINS="http://localhost:3000"
#   ollama serve

# ============================================
# OPTIONAL: Create the NexusNights Sidekick Model
# ============================================
# Run this command to create a custom model with the GOTCHA framework:
#
#   ollama create nexus-sidekick -f nexus-agent.json
#
# Then update OLLAMA_MODEL to use it:
#   OLLAMA_MODEL=nexus-sidekick
